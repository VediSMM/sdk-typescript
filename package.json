{
  "name": "@vedismm/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript and JavaScript SDK for VediSMM API v1",
  "license": "MIT",
  "homepage": "https://vedismm.ru/docs/api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VediSMM/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/VediSMM/sdk-typescript/issues"
  },
  "keywords": ["vedismm", "sdk", "social-media", "api", "typescript"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/src",
    "README.md",
    "README.ru.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "operations:sync": "node scripts/sync-operations.mjs",
    "operations:check": "node scripts/sync-operations.mjs --check",
    "test": "npm run operations:check && npm run build && node --test dist/test/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "docs:check": "node scripts/check-docs.mjs",
    "examples:check": "tsc -p tsconfig.json --noEmit",
    "secrets:check": "node scripts/check-secrets.mjs",
    "pack:check": "node scripts/check-package.mjs",
    "verify": "npm run typecheck && npm test && npm run docs:check && npm run examples:check && npm run secrets:check && npm run pack:check",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "24.0.15",
    "typescript": "5.8.3"
  }
}
